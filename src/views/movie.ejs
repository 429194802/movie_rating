<%- include('partials/head', { title: `${movie.title} - ${siteName}` }) %>
<main class="shell">
  <a class="back-link" href="/">返回列表</a>
  <section class="detail">
    <div class="detail-poster">
      <% if (movie.poster) { %>
        <img src="/poster?url=<%= encodeURIComponent(movie.poster) %>" alt="<%= movie.title %> 海报">
      <% } else { %>
        <div class="poster-fallback large"><%= movie.title.slice(0, 2) %></div>
      <% } %>
    </div>
    <div class="detail-main">
      <p class="eyebrow"><%= [movie.genre, movie.region].filter(Boolean).join(' / ') || '电影' %></p>
      <h1><%= movie.title %></h1>
      <p class="meta"><%= [movie.releaseDate, movie.duration].filter(Boolean).join(' / ') %></p>
      <div class="ratings">
        <div><span>本站评分</span><strong><%= movie.averageScore || '暂无' %></strong><small><%= movie.ratingCount %> 人评分</small></div>
        <div><span>豆瓣评分</span><strong><%= movie.doubanScore || '暂无' %></strong><small><%= movie.doubanVotes || 0 %> 人标记</small></div>
      </div>
      <% if (movie.directors.length) { %><p><strong>导演：</strong><%= movie.directors.join('、') %></p><% } %>
      <% if (movie.casts.length) { %><p><strong>主演：</strong><%= movie.casts.join('、') %></p><% } %>
      <a class="douban-link" href="<%= movie.doubanUrl %>" rel="noreferrer" target="_blank">查看豆瓣条目</a>
    </div>
  </section>

  <section class="forms">
    <form method="post" action="/movie/<%= movie.id %>/rating" class="panel">
      <h2>给这部电影评分</h2>
      <label for="score">评分（1-10）</label>
      <input id="score" name="score" type="number" min="1" max="10" step="1" required>
      <button type="submit">提交评分</button>
    </form>

    <form method="post" action="/movie/<%= movie.id %>/comments" class="panel">
      <h2>写短评</h2>
      <label for="author">昵称</label>
      <input id="author" name="author" maxlength="24" placeholder="匿名用户">
      <label for="body">评论</label>
      <textarea id="body" name="body" minlength="2" maxlength="800" required></textarea>
      <button type="submit">发布评论</button>
    </form>
  </section>

  <section id="comments" class="comments">
    <h2>观众评论</h2>
    <% if (!movie.comments.length) { %>
      <p class="muted">还没有评论。</p>
    <% } %>
    <% movie.comments.forEach((comment) => { %>
      <article class="comment">
        <div><strong><%= comment.author %></strong><time><%= new Date(comment.createdAt).toLocaleString('zh-CN') %></time></div>
        <p><%= comment.body %></p>
      </article>
    <% }) %>
  </section>
</main>
<%- include('partials/footer') %>
