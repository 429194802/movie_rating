[Unit]
Description=Movie Rating Node.js service
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/movie_rating
Environment=NODE_ENV=production
EnvironmentFile=/opt/movie_rating/.env
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
